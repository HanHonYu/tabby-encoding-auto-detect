h3 自动编码检测

.form-group
  label.form-check
    input.form-check-input(type='checkbox', [(ngModel)]='enabled', (ngModelChange)='saveConfig()')
    span.form-check-label 启用自动编码检测

.form-group
  label 置信度阈值 ({{confidenceThreshold * 100 | number: '1.0-1'}}%)
  input.form-control-range(type='range', min='0.1', max='1.0', step='0.05', [(ngModel)]='confidenceThreshold', (ngModelChange)='saveConfig()')

.form-group
  label 检测样本大小（字节）
  input.form-control(type='number', [(ngModel)]='sampleSize', (ngModelChange)='saveConfig()')

.form-group
  label.form-check
    input.form-check-input(type='checkbox', [(ngModel)]='autoSwitchEncoding', (ngModelChange)='saveConfig()')
    span.form-check-label 检测到编码时自动切换

.form-group
  label.form-check
    input.form-check-input(type='checkbox', [(ngModel)]='logDetectionResults', (ngModelChange)='saveConfig()')
    span.form-check-label 记录检测结果

.form-group
  label 首选编码
  .form-text.text-muted 编码检测优先级顺序
  select.form-control(multiple, [(ngModel)]='preferredEncodings', (ngModelChange)='saveConfig()', size='5')
    option(*ngFor='let enc of availableEncodings', [value]='enc', [selected]='preferredEncodings.includes(enc)') {{enc}}

.form-group
  label 备用编码
  select.form-control([(ngModel)]='fallbackEncoding', (ngModelChange)='saveConfig()')
    option(*ngFor='let enc of availableEncodings', [value]='enc') {{enc}}
